include: "rules/common.smk"
include: "rules/preparation.smk"
include: "rules/metrics.smk"
include: "rules/after_scoring.smk"


rule all:
    input:
        # build a single list of file paths; avoid inserting `None` values
        (expand("results/preprocessing/splits/{name}.split.done", name=config["name"]) if "preprocessing" in config else []) +
        (expand("results/metrics/{name_scored}_{label}_{prediction}_{positive_value}_{threshold_steps}_{threshold_range}_metrics.csv.gz", 
        name=config["name"], 
        name_scored=config["name_scored"],
        label=config["label"], 
        prediction=config["prediction"], 
        positive_value=config["positive_value"], 
        threshold_steps=config["threshold_steps"], 
        threshold_range=config["threshold_range"]
        ) if "metrics" in config else [])


rule all_metrics:
    input:
        expand("results/metrics/{name_scored}_{label}_{prediction}_{positive_value}_{threshold_steps}_{threshold_range}_metrics.csv.gz", 
        name_scored=config["name_scored"],
        label=config["label"], 
        prediction=config["prediction"], 
        positive_value=config["positive_value"], 
        threshold_steps=config["threshold_steps"], 
        threshold_range=config["threshold_range"]
        ),


rule preprocessing:
    input:
        expand("results/preprocessing/splits/{name}.split.done", name=config["name"]),
